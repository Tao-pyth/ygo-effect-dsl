{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tao-pyth/ygo-effect-dsl/experiment.schema.json",
  "title": "ygo-effect-dsl Experiment v0.4",
  "type": "object",
  "required": [
    "schema_version", "experiment_id", "objective", "deck", "player",
    "turn_limit", "information_mode", "information_policy", "evaluate_at", "success_predicate",
    "evaluator", "search", "interruption", "replay", "scenario"
  ],
  "properties": {
    "schema_version": {"const": "0.4"},
    "experiment_id": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "deck": {
      "type": "object",
      "required": ["id", "source"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "source": {"enum": ["fixed", "inline", "ydk"]},
        "main": {"$ref": "#/$defs/cardCodes"},
        "extra": {"$ref": "#/$defs/cardCodes"},
        "side": {"$ref": "#/$defs/cardCodes"},
        "path": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"source": {"const": "inline"}}},
          "then": {"required": ["main", "extra", "side"]}
        },
        {
          "if": {"properties": {"source": {"const": "ydk"}}},
          "then": {"required": ["path"]}
        }
      ]
    },
    "player": {
      "type": "object",
      "required": ["starting_player", "perspective"],
      "properties": {
        "starting_player": {"enum": [0, 1]},
        "perspective": {"enum": [0, 1]}
      }
    },
    "turn_limit": {"type": "integer", "minimum": 1},
    "information_mode": {"enum": ["complete_information", "player_view", "sampled_private_state"]},
    "information_policy": {
      "type": "object",
      "required": ["schema_version", "policy_id", "deck_order", "opening_hand", "sampling_reference"],
      "properties": {
        "schema_version": {"const": "information-policy-v1"},
        "policy_id": {"type": "string", "pattern": "^infopol_[0-9a-f]{64}$"},
        "deck_order": {"enum": ["known", "unknown"]},
        "opening_hand": {"enum": ["natural", "fixed", "probability_distribution"]},
        "sampling_reference": {"type": ["object", "null"]}
      },
      "additionalProperties": false
    },
    "evaluate_at": {"type": "string", "minLength": 1},
    "success_predicate": {"$ref": "#/$defs/plugin"},
    "evaluator": {"$ref": "#/$defs/plugin"},
    "search": {
      "type": "object",
      "required": ["strategy", "budget"],
      "properties": {
        "strategy": {"type": "string", "minLength": 1},
        "budget": {
          "type": "object",
          "anyOf": [{"required": ["max_nodes"]}, {"required": ["max_seconds"]}],
          "properties": {
            "max_nodes": {"type": "integer", "minimum": 1},
            "max_seconds": {"type": "number", "exclusiveMinimum": 0},
            "max_depth": {"type": "integer", "minimum": 1},
            "max_replays": {"type": "integer", "minimum": 1}
          }
        },
        "parameters": {"type": "object"}
      }
    },
    "interruption": {
      "type": "object",
      "required": ["mode", "definitions"],
      "properties": {
        "mode": {"enum": ["none", "scripted", "sampled", "specified"]},
        "sampling": {
          "type": "object",
          "required": ["schema_version", "sampler_id", "seed"],
          "properties": {
            "schema_version": {"const": "interruption-sampling-v1"},
            "sampler_id": {"const": "stable-digest-mod-v1"},
            "seed": {"type": "integer", "minimum": 0}
          }
        },
        "composition": {
          "type": "object",
          "properties": {
            "schema_version": {"const": "multi-interruption-composition-v1"},
            "opportunity_policy": {"const": "all_core_offered"},
            "branching_policy": {"const": "pass_or_one_activation_per_core_request"},
            "priority_policy": {"const": "ascending_priority_then_definition_id"},
            "opponent_action_scope": {"const": "specified_sources_only"}
          },
          "additionalProperties": false
        },
        "definitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "priority": {"type": "integer", "minimum": 0},
              "max_activations": {"type": "integer", "minimum": 1},
              "source_card_code": {"type": "integer", "minimum": 1},
              "source_player": {"enum": [0, 1]},
              "source_zone": {"enum": ["hand", "field"]},
              "core_location": {"enum": [4, 8]},
              "sequence": {"type": "integer", "minimum": 0},
              "response_roles": {
                "type": "array",
                "items": {"enum": ["cost", "target", "option"]}
              }
            }
          }
        }
      }
    },
    "replay": {
      "type": "object",
      "required": ["strict_versions"],
      "properties": {"strict_versions": {"type": "boolean"}}
    },
    "scenario": {
      "type": "object",
      "required": ["schema_version", "opening_hand"],
      "properties": {
        "schema_version": {"const": "scenario-v1"},
        "opening_hand": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": {"enum": ["fixed", "random", "conditional"]},
            "cards": {"$ref": "#/$defs/cardCodes"},
            "seed": {"type": "integer", "minimum": 0},
            "size": {"type": "integer", "minimum": 1},
            "max_attempts": {"type": "integer", "minimum": 1},
            "conditions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": {"type": "integer", "minimum": 1},
                  "min_count": {"type": "integer", "minimum": 0},
                  "max_count": {"type": "integer", "minimum": 0}
                }
              }
            }
          },
          "allOf": [
            {
              "if": {"properties": {"mode": {"const": "fixed"}}},
              "then": {"required": ["cards"]}
            },
            {
              "if": {"properties": {"mode": {"enum": ["random", "conditional"]}}},
              "then": {"required": ["seed"]}
            },
            {
              "if": {"properties": {"mode": {"const": "conditional"}}},
              "then": {"required": ["conditions"]}
            }
          ]
        },
        "initial_state": {
          "type": "object",
          "required": ["schema_version", "turn_player", "public_cards"],
          "properties": {
            "schema_version": {"const": "board-break-initial-state-v1"},
            "turn_player": {"const": 0},
            "public_cards": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["card_code", "owner", "controller", "location", "sequence", "position", "visibility"],
                "properties": {
                  "card_code": {"type": "integer", "minimum": 1},
                  "owner": {"type": "integer", "enum": [0, 1]},
                  "controller": {"type": "integer", "enum": [0, 1]},
                  "location": {"enum": ["monster_zone", "spell_trap_zone", "graveyard", "banished"]},
                  "sequence": {"type": "integer", "minimum": 0},
                  "position": {"enum": ["face_up_attack", "face_up_defense"]},
                  "visibility": {"const": "public"}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "runner": {
      "type": "object",
      "required": ["adapter", "scenario_id"],
      "properties": {
        "adapter": {"type": "string", "minLength": 1},
        "scenario_id": {"type": "string", "minLength": 1}
      }
    }
  },
  "$defs": {
    "cardCodes": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "plugin": {
      "type": "object",
      "required": ["id", "version", "config"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "config": {"type": "object"}
      }
    }
  }
}
